# PostCraft Backend Environment Variables
# OpenAI 字段对齐 studyx-agent-backend/config/api_keys.local.json

# LLM provider: deepseek | openai
LLM_PROVIDER=deepseek

# DeepSeek（主模型）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（备用 LLM + 封面配图）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_SKIP_PROXY=true

# Server
DEBUG=true
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

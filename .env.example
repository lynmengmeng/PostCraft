# PostCraft Backend Environment Variables
# OpenAI 字段对齐 studyx-agent-backend/config/api_keys.local.json
# 也可复制 studyx 的 json 到 PostCraft/config/api_keys.local.json，或设置：
# API_KEYS_FILE=/path/to/studyx-agent-backend/config/api_keys.local.json

# LLM provider: deepseek | openai
LLM_PROVIDER=deepseek

# DeepSeek（主模型）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（备用 LLM + 封面配图）
# 也可复制 studyx-agent-backend/config/api_keys.local.json 到 PostCraft/config/api_keys.local.json
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_IMAGE_MODEL=gpt-image-2
# LLM 走直连；配图 API 对齐 studyx，不受此项影响（仍使用 SDK 默认直连）
OPENAI_SKIP_PROXY=true

# Server
DEBUG=true
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

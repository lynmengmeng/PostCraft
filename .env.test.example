# PostCraft 测试环境后端配置
# 复制到 /opt/postcraft/.env 并填入密钥

LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI 留空即可，由 api_keys.local.json 补齐（配图 API）
OPENAI_SKIP_PROXY=true

# 可选：直接指向 studyx 的 Key 文件，无需软链
# API_KEYS_FILE=/opt/studyx-agent-backend/config/api_keys.local.json

DEBUG=false
CORS_ORIGINS=https://postcraft.studyx.ai,http://localhost:3002

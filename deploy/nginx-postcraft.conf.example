# PostCraft 测试环境 nginx 配置示例（路径部署，无需新子域名）
# 将以下 location 块追加到 test.studyx.ai 的现有 server { } 中

# PostCraft API：/postcraft-api/api/* -> 127.0.0.1:18231/api/*
location /postcraft-api/ {
    proxy_pass http://127.0.0.1:18231/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
}

# PostCraft Web：/postcraft/* -> Next.js :3002（需 NEXT_PUBLIC_BASE_PATH=/postcraft）
location /postcraft/ {
    proxy_pass http://127.0.0.1:3002/postcraft/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
}

# 可选：/postcraft 重定向到 /postcraft/
location = /postcraft {
    return 301 /postcraft/;
}
